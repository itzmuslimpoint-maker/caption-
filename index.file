<!-- ============ ALL FEATURES GRID ============ -->
<section class="all-features" id="all-features">
  <div class="container">
    <div class="section-header reveal">
      <div class="section-label">\u26a1 Everything Included</div>
      <h2 class="section-title">Everything you need to make <span class="gradient-text">better videos</span></h2>
      <p class="section-subtitle">A complete creative suite powered by state-of-the-art AI \u2014 from auto-captions to voice cloning to generative B-roll.</p>
    </div>

    <div class="features-masonry">
      <div class="fcard fcard-span2 reveal">
        <span class="fcard-icon">\ud83c\udfac</span>
        <h3 class="fcard-title">AI Editing</h3>
        <p class="fcard-desc">Explore a library of 50+ diverse styles and transform your footage into a finished video in minutes. AI handles every cut, transition, zoom, and effect automatically.</p>
        <span class="fcard-tag tag-orange">Most Popular</span>
      </div>

      <div class="fcard reveal reveal-delay-1">
        <span class="fcard-icon">\ud83d\udcac</span>
        <h3 class="fcard-title">Chat-Based Editor</h3>
        <p class="fcard-desc">Use plain-language prompts to direct changes. "Make it snappier", "Add a retro vibe" \u2014 AI understands your intent.</p>
        <span class="fcard-tag tag-purple">Max Plan</span>
      </div>

      <div class="fcard reveal reveal-delay-1">
        <span class="fcard-icon">\ud83d\udcdd</span>
        <h3 class="fcard-title">Automatic Captions</h3>
        <p class="fcard-desc">Generate perfectly timed captions with 99% accuracy in 100+ languages. Choose from hundreds of trending caption styles.</p>
        <span class="fcard-tag tag-blue">Pro+</span>
      </div>

      <div class="fcard reveal reveal-delay-2">
        <span class="fcard-icon">\ud83c\udf0d</span>
        <h3 class="fcard-title">AI Translation & Dubbing</h3>
        <p class="fcard-desc">Translate and lip-dub your videos into 30+ languages. Reach a global audience without re-recording anything.</p>
        <span class="fcard-tag tag-orange">New</span>
      </div>

      <div class="fcard reveal reveal-delay-2">
        <span class="fcard-icon">\ud83e\uddec</span>
        <h3 class="fcard-title">Realistic AI Actors</h3>
        <p class="fcard-desc">Generate new AI characters from scratch or create a digital twin of yourself. Reuse across unlimited videos.</p>
        <span class="fcard-tag tag-purple">Max Plan</span>
      </div>

      <div class="fcard reveal reveal-delay-3">
        <span class="fcard-icon">\ud83d\udc41\ufe0f</span>
        <h3 class="fcard-title">Eye Contact Correction</h3>
        <p class="fcard-desc">Automatically fix inconsistent eye contact, awkward glances, and off-screen looks \u2014 AI aligns your gaze to the lens.</p>
        <span class="fcard-tag tag-green">AI Magic</span>
      </div>

      <div class="fcard reveal reveal-delay-1">
        <span class="fcard-icon">\ud83c\udfb5</span>
        <h3 class="fcard-title">AI Music & Sound Effects</h3>
        <p class="fcard-desc">Generate original royalty-free music tailored to your video's mood, or add punchy sound effects with one tap.</p>
        <span class="fcard-tag tag-orange">Generative</span>
      </div>

      <div class="fcard reveal reveal-delay-2">
        <span class="fcard-icon">\ud83d\udd07</span>
        <h3 class="fcard-title">AI Denoise</h3>
        <p class="fcard-desc">Remove background noise, echoes, and hiss from your recordings in seconds. Achieve studio-quality audio from any environment.</p>
        <span class="fcard-tag tag-blue">Pro+</span>
      </div>

      <div class="fcard reveal reveal-delay-3">
        <span class="fcard-icon">\u2702\ufe0f</span>
        <h3 class="fcard-title">Trim Pauses & Filler Words</h3>
        <p class="fcard-desc">Automatically detect and remove "um", "uh", and awkward silences. Get a tighter, more professional delivery instantly.</p>
        <span class="fcard-tag tag-green">Time Saver</span>
      </div>

      <div class="fcard fcard-span2 reveal">
        <span class="fcard-icon">\ud83c\udfa5</span>
        <h3 class="fcard-title">AI B-Roll Generator</h3>
        <p class="fcard-desc">Automatically generate and overlay contextually relevant B-roll footage based on what you're saying in your video. No stock footage library needed \u2014 AI creates custom visuals that perfectly match your narration.</p>
        <span class="fcard-tag tag-purple">Generative AI</span>
      </div>

      <div class="fcard reveal">
        <span class="fcard-icon">\ud83d\uddbc\ufe0f</span>
        <h3 class="fcard-title">AI Image Generation</h3>
        <p class="fcard-desc">Generate custom images, thumbnails, and graphics to complement your video \u2014 all from a text prompt.</p>
        <span class="fcard-tag tag-orange">Max Plan</span>
      </div>

      <div class="fcard reveal reveal-delay-1">
        <span class="fcard-icon">\ud83c\udfad</span>
        <h3 class="fcard-title">AI Voice Clone</h3>
        <p class="fcard-desc">Clone your own voice to generate new narration without re-recording. Maintain your authentic sound at scale.</p>
        <span class="fcard-tag tag-purple">Scale Plan</span>
      </div>

      <div class="fcard reveal reveal-delay-2">
        <span class="fcard-icon">\ud83d\udcf1</span>
        <h3 class="fcard-title">Multi-Platform Export</h3>
        <p class="fcard-desc">Export perfectly sized videos for TikTok, Instagram Reels, YouTube Shorts, LinkedIn, and more with one tap.</p>
        <span class="fcard-tag tag-blue">All Plans</span>
      </div>
    </div>
  </div>
</section>

<!-- ============ HOW IT WORKS ============ -->
<section class="how-it-works" id="how">
  <div class="container">
    <div class="section-header reveal">
      <div class="section-label">\ud83d\ude80 How It Works</div>
      <h2 class="section-title">From upload to <span class="gradient-text">published</span> in 4 steps</h2>
      <p class="section-subtitle">The fastest path from raw footage to polished, publish-ready content \u2014 no editing skills required.</p>
    </div>

    <div class="steps-grid">
      <div class="step-card reveal">
        <div class="step-number active">1</div>
        <h3 class="step-title">Upload your video</h3>
        <p class="step-desc">Import from your phone, camera, or drag-and-drop any file. MP4, MOV, AVI \u2014 all formats supported.</p>
      </div>
      <div class="step-card reveal reveal-delay-1">
        <div class="step-number">2</div>
        <h3 class="step-title">Pick a style</h3>
        <p class="step-desc">Choose from 50+ curated AI editing styles, or describe what you want in the chat editor.</p>
      </div>
      <div class="step-card reveal reveal-delay-2">
        <div class="step-number">3</div>
        <h3 class="step-title">AI edits for you</h3>
        <p class="step-desc">Captions automatically cuts, captions, adds B-roll, music, and effects \u2014 all in under 2 minutes.</p>
      </div>
      <div class="step-card reveal reveal-delay-3">
        <div class="step-number">4</div>
        <h3 class="step-title">Export & share</h3>
        <p class="step-desc">Download in 4K, or share directly to TikTok, Instagram, YouTube and more without leaving the app.</p>
      </div>
    </div>
  </div>
</section>

