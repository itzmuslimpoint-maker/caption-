<!-- ============ DEMO 2: CHAT EDITOR ============ -->
<section class="demo-section" style="background:#0d0d0d;padding:100px 0;">
  <div class="container">
    <div class="demo-layout reverse">
      <div class="demo-content reveal">
        <div class="section-label">\ud83d\udcac Chat Editor</div>
        <h2 class="demo-title">Edit like you <span class="gradient-text-purple">text</span></h2>
        <p class="demo-desc">Captions' chat-based editor handles everything from minor tweaks to abstract creative requests. Just describe what you want in plain English, and AI does the rest \u2014 no timeline scrubbing needed.</p>

        <div class="demo-list">
          <div class="demo-list-item">
            <div class="check">\u2713</div>
            "Make this more energetic" \u2014 AI re-paces your video
          </div>
          <div class="demo-list-item">
            <div class="check">\u2713</div>
            "Remove all the pauses" \u2014 silence trimmed in seconds
          </div>
          <div class="demo-list-item">
            <div class="check">\u2713</div>
            "Add a dark cinematic look" \u2014 color grade applied instantly
          </div>
          <div class="demo-list-item">
            <div class="check">\u2713</div>
            Handles abstract requests with contextual understanding
          </div>
        </div>
        <a href="#signup" class="btn btn-primary">Try Chat Editor \u2192</a>
      </div>

      <div class="demo-visual reveal reveal-delay-2">
        <!-- Chat Editor Mockup -->
        <div style="background:#111;border:1px solid rgba(255,255,255,0.07);border-radius:24px;overflow:hidden;box-shadow:0 30px 80px rgba(0,0,0,0.5);">
          <div style="padding:16px 20px;background:#161616;border-bottom:1px solid rgba(255,255,255,0.05);display:flex;align-items:center;gap:10px;">
            <div style="width:28px;height:28px;background:linear-gradient(135deg,#7C3AED,#C084FC);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;">\ud83d\udcac</div>
            <span style="font-size:14px;font-weight:600;">Chat Editor</span>
            <span style="margin-left:auto;padding:3px 10px;background:rgba(124,58,237,0.1);border:1px solid rgba(124,58,237,0.2);border-radius:9999px;font-size:11px;font-weight:600;color:#C084FC;">MAX</span>
          </div>
          <div style="padding:20px;display:flex;flex-direction:column;gap:14px;min-height:380px;">
            <!-- AI message -->
            <div style="display:flex;gap:10px;align-items:flex-start;">
              <div style="width:28px;height:28px;background:linear-gradient(135deg,#7C3AED,#C084FC);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;">\u2726</div>
              <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.06);border-radius:4px 16px 16px 16px;padding:12px 16px;font-size:13px;color:rgba(255,255,255,0.7);line-height:1.6;max-width:320px;">
                Hi! I'm your AI editor. Upload a video and tell me what you'd like to do with it. I can cut scenes, add effects, change the mood, add captions \u2014 anything you need!
              </div>
            </div>
            <!-- User message -->
            <div style="display:flex;gap:10px;align-items:flex-start;justify-content:flex-end;">
              <div style="background:rgba(255,92,0,0.1);border:1px solid rgba(255,92,0,0.2);border-radius:16px 4px 16px 16px;padding:12px 16px;font-size:13px;color:rgba(255,255,255,0.85);line-height:1.6;max-width:280px;">
                Make this more cinematic and remove all the awkward pauses
              </div>
              <div style="width:28px;height:28px;background:#333;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;">\ud83d\udc64</div>
            </div>
            <!-- AI response -->
            <div style="display:flex;gap:10px;align-items:flex-start;">
              <div style="width:28px;height:28px;background:linear-gradient(135deg,#7C3AED,#C084FC);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;">\u2726</div>
              <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.06);border-radius:4px 16px 16px 16px;padding:12px 16px;font-size:13px;color:rgba(255,255,255,0.7);line-height:1.6;max-width:320px;">
                Done! I've:<br>
                \u2705 Applied a cinematic color grade<br>
                \u2705 Removed 7 awkward pauses<br>
                \u2705 Added smooth transitions<br>
                \u2705 Adjusted audio pacing<br><br>
                <span style="color:rgba(255,255,255,0.4);">Preview ready. Want any adjustments?</span>
              </div>
            </div>
            <!-- Input bar -->
            <div style="margin-top:auto;display:flex;gap:10px;align-items:center;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:12px;padding:12px 16px;">
              <span style="font-size:13px;color:rgba(255,255,255,0.25);flex:1;">Type an edit instruction...</span>
              <button style="background:linear-gradient(135deg,#FF5C00,#FF9A3C);border:none;width:32px;height:32px;border-radius:8px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:14px;">\u2192</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

